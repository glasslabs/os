# GlassOS common kernel config fragment — applied to all boards.
# Board-specific fragments (board/<board>/linux.config) are applied after this.

# ── Boot / panic ─────────────────────────────────────────────────────────────
# Prevent any in-kernel default cmdline from overriding U-Boot's bootargs.
CONFIG_CMDLINE=""
# Auto-reboot after a kernel panic.
CONFIG_PANIC_TIMEOUT=5

# ── systemd requirements ──────────────────────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_BLK_CGROUP=y
CONFIG_INOTIFY_USER=y
CONFIG_FHANDLE=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_AUTOFS_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_SECURITYFS=y

# ── Partition tables (required for hybrid GPT disk) ───────────────────────────
CONFIG_PARTITION_ADVANCED=y
CONFIG_EFI_PARTITION=y
CONFIG_MSDOS_PARTITION=y

# ── Filesystems ───────────────────────────────────────────────────────────────
# erofs — used for the read-only system (rootfs) partitions.
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_ZIP_LZ4=y
# ext4 — used for overlay and data partitions.
CONFIG_EXT4_FS=y
# VFAT/FAT — required to mount the boot partition.
CONFIG_MSDOS_FS=y
CONFIG_VFAT_FS=y

# ── DRM/KMS — common to all supported RPi boards ─────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_VC4=y
CONFIG_DRM_V3D=y

# ── WiFi (BCM43xxx on all supported RPi boards) ───────────────────────────────
# Built as a module so firmware can be loaded at runtime.
CONFIG_CFG80211=m
CONFIG_MAC80211=m
CONFIG_BRCMFMAC=m
CONFIG_BRCMFMAC_SDIO=y

# ── USB serial (useful for accessories and debugging) ─────────────────────────
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_GENERIC=y
CONFIG_USB_ACM=m

# ── GPIO ─────────────────────────────────────────────────────────────────────
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
