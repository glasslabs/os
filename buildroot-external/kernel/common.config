# GlassOS common kernel config fragment — applied to all boards.
# Board-specific fragments (board/<board>/linux.config) are applied after this.

# ── systemd requirements ──────────────────────────────────────────────────────
# systemd relies on cgroups, inotify, and a few syscalls that may not be
# present in minimal embedded defconfigs.
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_BLK_CGROUP=y
CONFIG_INOTIFY_USER=y
CONFIG_FHANDLE=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_AUTOFS_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_SECURITYFS=y

# ── WiFi (BCM43xxx on all supported RPi boards) ───────────────────────────────
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_BRCMFMAC=y
CONFIG_BRCMFMAC_SDIO=y

