#!/bin/sh
# Mount the /data partition and create required subdirectories on first boot.

DATA_DEV=/dev/mmcblk0p4
DATA_MNT=/data

case "$1" in
    start)
        echo "Mounting /data..."
        mkdir -p "$DATA_MNT"
        mount "$DATA_DEV" "$DATA_MNT"
        mkdir -p "$DATA_MNT/config" "$DATA_MNT/assets" "$DATA_MNT/modules"
        ;;
    stop)
        umount "$DATA_MNT" 2>/dev/null || true
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac

