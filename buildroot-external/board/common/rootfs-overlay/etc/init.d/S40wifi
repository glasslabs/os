#!/bin/sh
# Migrate wpa_supplicant.conf from the /boot FAT32 partition on first boot,
# then start wpa_supplicant and dhcpcd.
#
# To provision WiFi before first boot, place a wpa_supplicant.conf file on
# the /boot partition. It will be migrated to /data/config/ automatically and
# then removed from /boot so the PSK is not left on a world-readable partition.

BOOT_CONF=/boot/wpa_supplicant.conf
DATA_CONF=/data/config/wpa_supplicant.conf

case "$1" in
    start)
        # If a wpa_supplicant.conf was dropped on /boot, it always wins.
        if [ -f "$BOOT_CONF" ]; then
            echo "Applying wpa_supplicant.conf from /boot..."
            mkdir -p /data/config
            cp "$BOOT_CONF" "$DATA_CONF"
            rm -f "$BOOT_CONF"
        fi

        if [ -f "$DATA_CONF" ]; then
            wpa_supplicant -B -i wlan0 -c "$DATA_CONF"
        else
            echo "No wpa_supplicant.conf found; WiFi not configured."
        fi

        dhcpcd eth0 wlan0 &
        ;;
    stop)
        wpa_cli -i wlan0 terminate 2>/dev/null || true
        killall dhcpcd 2>/dev/null || true
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac

