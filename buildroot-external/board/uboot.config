# GlassOS U-Boot config fragment — applied on top of every board's defconfig.
# Aligns with the boot.scr A/B boot script requirements.

# Boot behaviour
# CONFIG_LOCALVERSION_AUTO is not set
CONFIG_DISTRO_DEFAULTS=y
CONFIG_BOOTDELAY=-2

# Environment: store nowhere (we use a dedicated raw bootstate partition).
# CONFIG_ENV_IS_IN_FAT is not set
# CONFIG_ENV_IS_IN_EXT4 is not set
CONFIG_ENV_IS_NOWHERE=y

# Filesystem support required to load the kernel from ext4 rootfs.
CONFIG_FS_EXT4=y
CONFIG_FS_FAT=y

# Partition table: GPT (hybrid for rpi4, pure GPT for rpi5).
CONFIG_EFI_PARTITION=y

# Commands used by the boot script.
CONFIG_CMD_SETEXPR=y
CONFIG_CMD_FILEENV=y

# Reduce attack surface — no EFI application loader needed.
# CONFIG_EFI_LOADER is not set

# Unnecessary features.
# CONFIG_DFU is not set
# CONFIG_CMD_DFU is not set
# CONFIG_TOOLS_MKEFICAPSULE is not set

