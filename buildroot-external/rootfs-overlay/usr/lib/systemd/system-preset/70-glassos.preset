# GlassOS systemd service presets.
# Applied during post-build via: systemctl --root=<TARGET> preset-all

enable boot.mount
enable data.mount
enable overlay.mount
enable glass-agent.service
enable glassos-data-dirs.service
enable glassos-bind.target
enable glassos-expand.service
enable glassos-wifi-provision.service
enable NetworkManager.service
disable wpa_supplicant.service
enable dropbear.service
enable systemd-growfs@data.service
