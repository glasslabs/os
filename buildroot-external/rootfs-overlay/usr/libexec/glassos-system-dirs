#!/bin/sh
# glassos-system-dirs — create persistent system directories and seed default
# files on /data before bind-mount units project them onto the read-only rootfs.

# NetworkManager
mkdir -p /data/NetworkManager/system-connections
mkdir -p /data/NetworkManager/lib

# SSH host keys
mkdir -p /data/dropbear

# Persistent journal
mkdir -p /data/journal

# Hostname — copy the rootfs default on first boot so the value can be
# changed by writing to /data/hostname without touching the read-only rootfs.
if [ ! -f /data/hostname ]; then
    cp -fp /etc/hostname /data/hostname
fi

