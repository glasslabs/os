#!/bin/sh
# glassos-system-dirs — create persistent system directories and seed default
# files on /data before bind-mount units project them onto the read-only rootfs.

mkdir -p /data/etc

# NetworkManager
mkdir -p /data/etc/NetworkManager/system-connections
mkdir -p /data/var/lib/NetworkManager

if [ ! -f /data/etc/hostname ]; then
    cp -fp /etc/hostname /data/etc/hostname
fi

# SSH host keys
mkdir -p /data/etc/dropbear

# Persistent journal
mkdir -p /data/var/log/journal
